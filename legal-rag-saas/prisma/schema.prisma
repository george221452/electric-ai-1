generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // Adăugat pentru credentials auth
  isAdmin       Boolean   @default(false) @map("is_admin")
  accounts      Account[]
  sessions      Session[]
  
  ownedWorkspaces Workspace[]
  workspaceUsers  WorkspaceUser[]
  documents       Document[]
  apiKeys         ApiKey[]
  subscriptions   Subscription[]
  tokenBalance    TokenBalance?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Workspace {
  id          String          @id @default(uuid())
  name        String
  description String?
  slug        String          @unique
  ownerId     String          @map("owner_id")
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  users       WorkspaceUser[]
  documents   Document[]
  ragConfigId String          @default("generic-document") @map("rag_config_id")
  isPublic    Boolean         @default(false) @map("is_public")
  settings    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceUser {
  id          String        @id @default(uuid())
  workspaceId String        @map("workspace_id")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_users")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Document {
  id            String       @id @default(uuid())
  workspaceId   String       @map("workspace_id")
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  fileType      String       @map("file_type")
  fileSize      Int          @map("file_size")
  storageKey    String       @unique @map("storage_key")
  status        DocumentStatus @default(PENDING)
  pageCount     Int?         @map("page_count")
  ragConfigId   String       @map("rag_config_id")
  paragraphs    Paragraph[]
  citations     Citation[]
  processingError String?    @map("processing_error")
  metadata      Json         @default("{}")
  indexedAt     DateTime?    @map("indexed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([status])
  @@index([workspaceId, status])
  @@map("documents")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  INDEXED
}

model Paragraph {
  id              String     @id @default(uuid())
  documentId      String     @map("document_id")
  document        Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content         String     @db.Text
  pageNumber      Int        @map("page_number")
  paragraphNumber Int        @map("paragraph_number")
  chapterTitle    String?    @map("chapter_title")
  sectionTitle    String?    @map("section_title")
  wordCount       Int        @map("word_count")
  charCount       Int        @map("char_count")
  keywords        String[]
  metadata        Json       @default("{}")
  isObligation    Boolean    @default(false) @map("is_obligation")
  isProhibition   Boolean    @default(false) @map("is_prohibition")
  isDefinition    Boolean    @default(false) @map("is_definition")
  articleNumber   String?    @map("article_number")
  paragraphLetter String?    @map("paragraph_letter")
  citations       Citation[]
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([documentId])
  @@index([keywords])
  @@index([articleNumber])
  @@map("paragraphs")
}

model Chat {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  title       String    @default("New Chat")
  documentIds String[]  @map("document_ids")
  messages    Message[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([workspaceId])
  @@index([userId])
  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String   @db.Text
  citations Citation[]
  metadata  Json     @default("{}")
  tokensUsed Int?    @map("tokens_used")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Citation {
  id            String    @id @default(uuid())
  messageId     String    @map("message_id")
  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  paragraphId   String    @map("paragraph_id")
  paragraph     Paragraph @relation(fields: [paragraphId], references: [id])
  documentId    String    @map("document_id")
  document      Document  @relation(fields: [documentId], references: [id])
  citationIndex Int       @map("citation_index")
  confidence    Int
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([messageId])
  @@map("citations")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("api_keys")
}

model TokenBalance {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance     Int      @default(0)
  totalUsed   Int      @default(0) @map("total_used")
  totalPurchased Int   @default(0) @map("total_purchased")
  lastRefillAt DateTime? @map("last_refill_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("token_balances")
}

model TokenUsage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int
  operation String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("token_usage")
}

model TokenTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int
  type      String   // 'credit' | 'debit'
  source    String   // 'purchase' | 'refill' | 'bonus' | 'usage'
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("token_transactions")
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId  String             @unique @map("stripe_customer_id")
  stripeSubscriptionId String?         @unique @map("stripe_subscription_id")
  stripePriceId     String?            @map("stripe_price_id")
  status            SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart DateTime?         @map("current_period_start")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([userId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

model Feedback {
  id          String   @id @default(uuid())
  query       String   @db.Text
  answer      String   @db.Text
  rating      Int      // 1 = thumbs down, 2 = thumbs up
  reason      String?  // Optional reason for the rating
  confidence  Int      // Confidence score at the time of feedback
  citations   Json?    // Citations included in the answer
  metadata    Json?    // Additional metadata (scenario type, etc.)
  userId      String?  @map("user_id")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([rating])
  @@index([createdAt])
  @@map("feedback")
}

// Setări pentru arhitectura RAG
model RagArchitectureSettings {
  id    String @id @default("global")
  
  // Arhitectura activă
  activeArchitecture String @default("legacy") @map("active_architecture")
  
  // Chunking settings
  chunkMaxSize                Int     @default(1500) @map("chunk_max_size")
  chunkMinSize                Int     @default(200) @map("chunk_min_size")
  chunkOverlap                Int     @default(100) @map("chunk_overlap")
  preserveParagraphBoundaries Boolean @default(true) @map("preserve_paragraph_boundaries")
  preserveSentenceBoundaries  Boolean @default(true) @map("preserve_sentence_boundaries")
  cleanDiacritics             Boolean @default(true) @map("clean_diacritics")
  removeExtraWhitespace       Boolean @default(true) @map("remove_extra_whitespace")
  fixHyphenatedWords          Boolean @default(true) @map("fix_hyphenated_words")
  
  // Embedding settings
  embeddingModel      String @default("text-embedding-3-small") @map("embedding_model")
  embeddingDimensions Int    @default(1536) @map("embedding_dimensions")
  embeddingBatchSize  Int    @default(100) @map("embedding_batch_size")
  
  // Legacy settings
  legacyUseKeywordSearch  Boolean @default(true) @map("legacy_use_keyword_search")
  legacyUseVectorSearch   Boolean @default(true) @map("legacy_use_vector_search")
  legacyMinScoreThreshold Float   @default(0.40) @map("legacy_min_score_threshold")
  legacyMaxResults        Int     @default(10) @map("legacy_max_results")
  legacyFinalResults      Int     @default(3) @map("legacy_final_results")
  legacySearchStrategy    String  @default("parallel") @map("legacy_search_strategy")
  legacyCombineMethod     String  @default("merge") @map("legacy_combine_method")
  legacyOpenaiModel       String  @default("gpt-4o-mini") @map("legacy_openai_model")
  legacyMaxTokens         Int     @default(500) @map("legacy_max_tokens")
  legacyTemperature       Float   @default(0.2) @map("legacy_temperature")
  legacySystemPrompt      String  @default("Esti un asistent specializat in normative electrice romanesti.") @map("legacy_system_prompt")
  legacyPromptTemplate    String  @default("standard") @map("legacy_prompt_template")
  legacyIncludeCitations  Boolean @default(true) @map("legacy_include_citations")
  legacyRequireCitations  Boolean @default(true) @map("legacy_require_citations")
  
  // Hybrid settings
  hybridUseKeywordSearch         Boolean @default(true) @map("hybrid_use_keyword_search")
  hybridUseVectorSearch          Boolean @default(true) @map("hybrid_use_vector_search")
  hybridUseSynonymExpansion      Boolean @default(false) @map("hybrid_use_synonym_expansion")
  hybridSynonymMaxVariants       Int     @default(3) @map("hybrid_synonym_max_variants")
  hybridUseNumericalBoost        Boolean @default(false) @map("hybrid_use_numerical_boost")
  hybridNumericalBoostWeight     Float   @default(0.3) @map("hybrid_numerical_boost_weight")
  hybridUseSmartRouter           Boolean @default(false) @map("hybrid_use_smart_router")
  hybridSmartRouterQuizThreshold Float   @default(0.75) @map("hybrid_smart_router_quiz_threshold")
  hybridSmartRouterNormalThreshold Float @default(0.5) @map("hybrid_smart_router_normal_threshold")
  hybridSmartRouterMaxRetries    Int     @default(2) @map("hybrid_smart_router_max_retries")
  hybridUseConfidenceOptimizer   Boolean @default(false) @map("hybrid_use_confidence_optimizer")
  hybridUseQueryUnderstanding    Boolean @default(false) @map("hybrid_use_query_understanding")
  hybridUseIntentDetection       Boolean @default(false) @map("hybrid_use_intent_detection")
  hybridMinScoreThreshold        Float   @default(0.40) @map("hybrid_min_score_threshold")
  hybridMaxResults               Int     @default(10) @map("hybrid_max_results")
  hybridFinalResults             Int     @default(3) @map("hybrid_final_results")
  hybridRerankEnabled            Boolean @default(false) @map("hybrid_rerank_enabled")
  hybridRerankMethod             String  @default("score") @map("hybrid_rerank_method")
  hybridOpenaiModel              String  @default("gpt-4o-mini") @map("hybrid_openai_model")
  hybridMaxTokens                Int     @default(600) @map("hybrid_max_tokens")
  hybridTemperature              Float   @default(0.2) @map("hybrid_temperature")
  hybridSystemPrompt             String  @default("Esti un asistent specializat in normative electrice romanesti.") @map("hybrid_system_prompt")
  hybridPromptTemplate           String  @default("adaptive") @map("hybrid_prompt_template")
  hybridIncludeCitations         Boolean @default(true) @map("hybrid_include_citations")
  hybridRequireCitations         Boolean @default(true) @map("hybrid_require_citations")
  hybridQuizEnabled              Boolean @default(true) @map("hybrid_quiz_enabled")
  hybridQuizStrictMode           Boolean @default(false) @map("hybrid_quiz_strict_mode")
  hybridQuizConfidenceThreshold  Int     @default(70) @map("hybrid_quiz_confidence_threshold")
  
  // Cache settings
  enableQueryCache       Boolean @default(true) @map("enable_query_cache")
  cacheTtlSeconds        Int     @default(3600) @map("cache_ttl_seconds")
  enableResultCache      Boolean @default(false) @map("enable_result_cache")
  resultCacheTtlSeconds  Int     @default(86400) @map("result_cache_ttl_seconds")
  
  // Debug settings
  showDebugInfo          Boolean @default(false) @map("show_debug_info")
  logQueries             Boolean @default(true) @map("log_queries")
  logPerformanceMetrics  Boolean @default(false) @map("log_performance_metrics")
  enableQueryTracing     Boolean @default(false) @map("enable_query_tracing")
  
  // Formatting settings
  answerFormat           String @default("markdown") @map("answer_format")
  includeSources         Boolean @default(true) @map("include_sources")
  includeConfidenceScore Boolean @default(true) @map("include_confidence_score")
  includeExecutionTime   Boolean @default(false) @map("include_execution_time")
  addDocumentBanner      Boolean @default(false) @map("add_document_banner")
  
  // Fallback settings
  fallbackOnLowConfidence      Boolean @default(true) @map("fallback_on_low_confidence")
  fallbackConfidenceThreshold  Int @default(40) @map("fallback_confidence_threshold")
  fallbackToGeneralKnowledge   Boolean @default(false) @map("fallback_to_general_knowledge")
  showClarificationOnNoResults Boolean @default(true) @map("show_clarification_on_no_results")
  
  // Document processing settings
  extractMetadata      Boolean @default(true) @map("extract_metadata")
  extractArticleNumbers Boolean @default(true) @map("extract_article_numbers")
  extractKeywords      Boolean @default(true) @map("extract_keywords")
  classifyParagraphs   Boolean @default(false) @map("classify_paragraphs")
  
  // Timestamps
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("rag_architecture_settings")
}
