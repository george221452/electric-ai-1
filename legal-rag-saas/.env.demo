# Configurație pentru DEMO (fără servicii externe)
NEXT_PUBLIC_DEMO_MODE=true
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=demo-secret-key-change-in-production

# OpenAI (necesar pentru AI)
OPENAI_API_KEY=sk-demo-key

# Database - SQLite pentru demo
DATABASE_URL=file:./prisma/demo.db

# Qdrant - skip în demo mode
QDRANT_URL=http://localhost:6333

# Redis - skip în demo mode
REDIS_URL=redis://localhost:6379

# Stripe - dezactivat în demo
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=demo
STRIPE_SECRET_KEY=demo
STRIPE_WEBHOOK_SECRET=demo
